% valPerformance = perform(net,valTargets,y_pred)
% testPerformance = perform(net,testTargets,y_pred)
% 
% % View the Network
% view(net)
% 
% %Plots
% %Uncomment these lines to enable various plots.
 figure, plotperform(bestTr)
